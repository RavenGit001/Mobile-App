<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Thesis.Mobile.Pages.DashboardPage"
             Title="Multi-Bread Dashboard"
             Background="{StaticResource BreadBackground}">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="{StaticResource PaddingLarge}" Spacing="{StaticResource PaddingLarge}">

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Border BackgroundColor="{StaticResource SystemStatusBackground}" 
                            StrokeShape="RoundRectangle 20" Padding="12,4">
                        <Label Text="{Binding SystemBannerText}" FontSize="12" FontAttributes="Bold" TextColor="#1B5E20"/>
                    </Border>
                    <Label Text="{Binding CurrentTime}" VerticalOptions="Center" FontSize="12" Opacity="0.6" FontAttributes="Bold"/>
                </HorizontalStackLayout>

                <Border Style="{StaticResource CardShadowStyle}" BackgroundColor="White" StrokeThickness="0">
                    <Grid ColumnDefinitions="*, Auto, *">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding TemperatureText}" Style="{StaticResource ValueTextStyle}" HorizontalOptions="Center"/>
                            <Label Text="TEMPERATURE" Style="{StaticResource LabelTextStyle}" CharacterSpacing="1" FontSize="10" HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <BoxView Grid.Column="1" WidthRequest="1" Color="#F0F0F0" Margin="10,5"/>

                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding HumidityText}" Style="{StaticResource ValueTextStyle}" HorizontalOptions="Center"/>
                            <Label Text="HUMIDITY" Style="{StaticResource LabelTextStyle}" CharacterSpacing="1" FontSize="10" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Recent Activity" Style="{StaticResource HeaderTextStyle}" FontSize="18"/>
                    <Border Style="{StaticResource CardShadowStyle}" BackgroundColor="White" StrokeThickness="0" Padding="20">
                        <VerticalStackLayout Spacing="15">
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Ellipse Fill="#FEE19E" WidthRequest="10" HeightRequest="10" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="Spanish Bread Detection" Margin="12,0" FontSize="13" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="2m ago" FontSize="11" Opacity="0.5" VerticalOptions="Center"/>
                            </Grid>
                            <BoxView HeightRequest="1" Color="#F5F5F5"/>
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Ellipse Fill="#ADE1F3" WidthRequest="10" HeightRequest="10" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="Environment Stabilized" Margin="12,0" FontSize="13" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="14m ago" FontSize="11" Opacity="0.5" VerticalOptions="Center"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" BackgroundColor="#FFF9E1" HeightRequest="130" StrokeShape="RoundRectangle 18" StrokeThickness="0">
                        <VerticalStackLayout VerticalOptions="Center" Spacing="8">
                            <Label Text="Spanish" Style="{StaticResource BreadTitleStyle}" HorizontalOptions="Center"/>
                            <Border BackgroundColor="White" StrokeShape="RoundRectangle 10" Padding="8,2" HorizontalOptions="Center">
                                <Label Text="{Binding SpanishBreadStatus}" FontSize="10" TextColor="{Binding SpanishBreadColor}" FontAttributes="Bold"/>
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" BackgroundColor="#FFEBE3" HeightRequest="130" StrokeShape="RoundRectangle 18" StrokeThickness="0">
                        <VerticalStackLayout VerticalOptions="Center" Spacing="8">
                            <Label Text="Ensaymada" Style="{StaticResource BreadTitleStyle}" HorizontalOptions="Center"/>
                            <Border BackgroundColor="White" StrokeShape="RoundRectangle 10" Padding="8,2" HorizontalOptions="Center">
                                <Label Text="{Binding EnsaymadaStatus}" FontSize="10" TextColor="{Binding EnsaymadaColor}" FontAttributes="Bold"/>
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2" BackgroundColor="#E3F6FF" HeightRequest="130" StrokeShape="RoundRectangle 18" StrokeThickness="0">
                        <VerticalStackLayout VerticalOptions="Center" Spacing="8">
                            <Label Text="Pan de Coco" Style="{StaticResource BreadTitleStyle}" HorizontalOptions="Center"/>
                            <Border BackgroundColor="White" StrokeShape="RoundRectangle 10" Padding="8,2" HorizontalOptions="Center">
                                <Label Text="{Binding PanDeCocoStatus}" FontSize="10" TextColor="{Binding PanDeCocoColor}" FontAttributes="Bold"/>
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="1"
                Text="VIEW FULL DETECTION LOG"
                Style="{StaticResource ValueTextStyle}"
                FontSize="14"
                CharacterSpacing="1"
                BackgroundColor="{StaticResource FABColor}"
                TextColor="White"
                HeightRequest="55"
                CornerRadius="15"
                Margin="20"
                Clicked="OnDetectionPageClicked"/>
    </Grid>
</ContentPage>